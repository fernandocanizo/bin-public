#!/usr/bin/env bash
# Pomodoro timer for Hyprland
# Usage: pomodoro start|stop|status|skip
# Cycles: 3x (Work 25m / Rest 5m), then 1x (Work 25m / Long Rest 20m)

set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}"
STATE_FILE="$STATE_DIR/pomodoro.state"
PID_FILE="$STATE_DIR/pomodoro.pid"
LOG_FILE="$STATE_DIR/pomodoro.log"
SKIP_FILE="$STATE_DIR/pomodoro.skip"

# Durations in seconds
WORK=1500       # 25*60
REST=300        # 5*60
LONG_REST=1200  # 20*60

# --- DBUS helper for notifications ---
_find_dbus() {
    if [[ -n "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
        return 0
    fi
    local addr
    addr=$(ps -u "$(id -u)" -o pid,comm 2>/dev/null | \
        awk '{print $1}' | \
        xargs -I{} cat /proc/{}/environ 2>/dev/null | \
        tr '\0' '\n' | grep '^DBUS_SESSION_BUS_ADDRESS=' | head -n1 | cut -d= -f2-)
    if [[ -n "$addr" ]]; then
        export DBUS_SESSION_BUS_ADDRESS="$addr"
        return 0
    fi
    if [[ -S "/run/user/$(id -u)/bus" ]]; then
        export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"
        return 0
    fi
    return 1
}

_notify() {
    local urgency="$1" title="$2" body="$3"
    if ! _find_dbus; then
        printf '%s WARN: no DBUS, notification skipped: %s\n' "$(date '+%F %T')" "$title" >> "$LOG_FILE"
        return 1
    fi
    notify-send --urgency="$urgency" "$title" "$body" 2>/dev/null || true
}

notify_work() {
    _notify critical "Pomodoro — WORK" "Focus time! 25 minutes of deep work."
}

notify_rest() {
    _notify normal "Pomodoro — REST" "Short break! 5 minutes to recharge."
}

notify_long_rest() {
    _notify normal "Pomodoro — LONG REST" "Big break! 20 minutes to relax."
}

# --- Daemon loop ---
run_daemon() {
    local step=0 phase duration end_time now remaining

    # If resuming from a skip, read the saved step
    if [[ -f "$STATE_FILE" ]]; then
        local saved_step
        IFS='|' read -r phase saved_step end_time < "$STATE_FILE" 2>/dev/null || true
        if [[ -n "${saved_step:-}" ]]; then
            step="$saved_step"
        fi
    fi

    # Start at the beginning of the current step
    while true; do
        case $step in
            0|2|4|6)
                phase="work"
                duration=$WORK
                notify_work
                ;;
            1|3|5)
                phase="rest"
                duration=$REST
                notify_rest
                ;;
            7)
                phase="long_rest"
                duration=$LONG_REST
                notify_long_rest
                ;;
        esac

        end_time=$(($(date +%s) + duration))
        printf '%s|%s|%s\n' "$phase" "$step" "$end_time" > "$STATE_FILE"

        # Sleep in 1-second slices so skip is responsive
        while true; do
            if [[ -f "$SKIP_FILE" ]]; then
                rm -f "$SKIP_FILE"
                break
            fi
            now=$(date +%s)
            remaining=$((end_time - now))
            if [[ $remaining -le 0 ]]; then
                break
            fi
            # Refresh state file occasionally for `status` accuracy
            if (( now % 10 == 0 )); then
                printf '%s|%s|%s\n' "$phase" "$step" "$end_time" > "$STATE_FILE"
            fi
            sleep 1
        done

        step=$(((step + 1) % 8))
    done
}

# --- Commands ---
cmd_start() {
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "Pomodoro already running (PID $(cat "$PID_FILE"))"
        exit 1
    fi

    rm -f "$PID_FILE" "$SKIP_FILE"
    printf '%s|%s|%s\n' "work" "0" "$(($(date +%s) + WORK))" > "$STATE_FILE"

    # Fork daemon to background, disown it from terminal
    (
        trap 'rm -f "$PID_FILE"; exit 0' TERM INT
        run_daemon
    ) &
    local pid=$!
    disown "$pid" 2>/dev/null || true
    echo "$pid" > "$PID_FILE"

    sleep 0.2
    if kill -0 "$pid" 2>/dev/null; then
        echo "Pomodoro started (PID $pid)"
    else
        echo "Failed to start pomodoro daemon"
        rm -f "$PID_FILE"
        exit 1
    fi
}

cmd_stop() {
    if [[ ! -f "$PID_FILE" ]]; then
        echo "Pomodoro not running"
        exit 1
    fi
    local pid
    pid=$(cat "$PID_FILE")
    if kill -TERM "$pid" 2>/dev/null; then
        # Wait briefly for cleanup
        for _ in {1..10}; do
            [[ -f "$PID_FILE" ]] || break
            sleep 0.1
        done
        rm -f "$PID_FILE" "$SKIP_FILE"
        echo "Pomodoro stopped"
    else
        rm -f "$PID_FILE" "$SKIP_FILE"
        echo "Pomodoro not running"
    fi
}

cmd_status() {
    if [[ ! -f "$STATE_FILE" ]]; then
        echo "Pomodoro not running"
        exit 1
    fi
    if [[ -f "$PID_FILE" ]] && ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "Pomodoro not running (stale state)"
        rm -f "$PID_FILE" "$STATE_FILE"
        exit 1
    fi

    local phase step end_time now remaining mins secs
    IFS='|' read -r phase step end_time < "$STATE_FILE"
    now=$(date +%s)
    remaining=$((end_time - now))
    [[ $remaining -lt 0 ]] && remaining=0

    mins=$((remaining / 60))
    secs=$((remaining % 60))

    local label
    case $phase in
        work) label="WORK" ;;
        rest) label="REST" ;;
        long_rest) label="LONG REST" ;;
        *) label="UNKNOWN" ;;
    esac

    printf '%s | %02d:%02d remaining (step %s/7)\n' "$label" "$mins" "$secs" "$step"
}

cmd_skip() {
    if [[ ! -f "$PID_FILE" ]] || ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "Pomodoro not running"
        exit 1
    fi
    touch "$SKIP_FILE"
    echo "Skipping to next phase..."
}

# Main
case "${1:-}" in
    start) cmd_start ;;
    stop)  cmd_stop ;;
    status) cmd_status ;;
    skip)  cmd_skip ;;
    *)
        cat <<'EOF'
Usage: pomodoro {start|stop|status|skip}

Pomodoro cycle:
  • Work 25 min → Rest 5 min  (x3)
  • Work 25 min → Long Rest 20 min  (x1)
  • Repeat

Notifications are sent via notify-send (mako on Hyprland).
EOF
        exit 1
        ;;
esac
