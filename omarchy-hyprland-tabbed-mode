#!/usr/bin/env python3
"""
Omarchy Hyprland tabbed/split workspace toggle.
Tabbed mode: all windows become floating and fill the monitor area
(minus waybar), so only the focused one is visible. Split mode:
windows return to normal tiled (dwindle) layout.
"""
import sys
import os
import json
import subprocess
import glob

STATE_DIR = "/tmp/omarchy-tabbed-mode"
WAYBAR_HEIGHT = 38
WAYBAR_POS = "bottom"  # read from ~/.config/waybar/config.jsonc if you move it


def hyprctl(args):
    cmd = ["hyprctl", "-j"] + args
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"hyprctl error: {result.stderr}", file=sys.stderr)
        return None
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return result.stdout.strip()


def hyprctl_dispatch(args):
    cmd = ["hyprctl", "dispatch"] + args
    result = subprocess.run(cmd, capture_output=True, text=True)
    return result.returncode == 0


def get_state_file(workspace_id):
    return f"{STATE_DIR}/workspace-{workspace_id}.json"


def is_tabbed(workspace_id):
    return os.path.exists(get_state_file(workspace_id))


def get_current_workspace():
    monitors = hyprctl(["monitors"])
    if not monitors:
        return None
    for m in monitors:
        if m.get("focused"):
            return m.get("activeWorkspace", {}).get("id")
    return None


def get_workspace_windows(workspace_id):
    clients = hyprctl(["clients"])
    if not clients:
        return []
    out = []
    for c in clients:
        if c.get("workspace", {}).get("id") == workspace_id:
            out.append({
                "address": c.get("address"),
                "floating": c.get("floating"),
                "class": c.get("class"),
            })
    return out


def get_monitor_for_workspace(workspace_id):
    monitors = hyprctl(["monitors"])
    if not monitors:
        return None
    # First check focused monitor
    for m in monitors:
        if m.get("activeWorkspace", {}).get("id") == workspace_id:
            return m
    # Fallback: search by workspace monitor assignment
    workspaces = hyprctl(["workspaces"])
    for w in workspaces or []:
        if w.get("id") == workspace_id:
            mon_name = w.get("monitor")
            for m in monitors:
                if m.get("name") == mon_name:
                    return m
    return None


def apply_tabbed_geometry(address, monitor):
    """Resize/move a floating window to fill monitor minus waybar."""
    x = monitor.get("x", 0)
    y = monitor.get("y", 0)
    w = monitor.get("width", 1920)
    h = monitor.get("height", 1080)

    if WAYBAR_POS == "bottom":
        h -= WAYBAR_HEIGHT
    elif WAYBAR_POS == "top":
        y += WAYBAR_HEIGHT
        h -= WAYBAR_HEIGHT

    # These dispatchers accept a window selector — no focus change needed
    hyprctl_dispatch(["movewindowpixel", "exact", str(x), str(y), f"address:{address}"])
    hyprctl_dispatch(["resizewindowpixel", "exact", str(w), str(h), f"address:{address}"])


def enable_tabbed(workspace_id):
    os.makedirs(STATE_DIR, exist_ok=True)

    monitor = get_monitor_for_workspace(workspace_id)
    if not monitor:
        print("Could not determine monitor", file=sys.stderr)
        return

    windows = get_workspace_windows(workspace_id)
    # Only affect currently-tiled windows; leave existing floaters alone
    targets = [w for w in windows if not w["floating"]]

    state = {"windows": [w["address"] for w in targets]}
    with open(get_state_file(workspace_id), "w") as f:
        json.dump(state, f)

    for w in targets:
        hyprctl_dispatch(["setfloating", f"address:{w['address']}"])
        apply_tabbed_geometry(w["address"], monitor)

    print(f"Workspace {workspace_id}: tabbed mode ({len(targets)} windows)")


def disable_tabbed(workspace_id):
    path = get_state_file(workspace_id)
    if not os.path.exists(path):
        print(f"Workspace {workspace_id} not in tabbed mode", file=sys.stderr)
        return

    with open(path) as f:
        state = json.load(f)

    for addr in state.get("windows", []):
        hyprctl_dispatch(["settiled", f"address:{addr}"])

    os.remove(path)
    print(f"Workspace {workspace_id}: split mode")


def handle_new_window(address):
    clients = hyprctl(["clients"])
    win = None
    for c in clients or []:
        if c.get("address") == address:
            win = c
            break
    if not win:
        return

    ws = win.get("workspace", {}).get("id")
    if ws is None or ws < 0:
        return
    if not is_tabbed(ws):
        return
    if win.get("floating"):
        return  # dialog/popup already floated by rules

    # Record it so we retile it later
    path = get_state_file(ws)
    with open(path) as f:
        state = json.load(f)
    if address not in state["windows"]:
        state["windows"].append(address)
        with open(path, "w") as f:
            json.dump(state, f)

    monitor = get_monitor_for_workspace(ws)
    if monitor:
        hyprctl_dispatch(["setfloating", f"address:{address}"])
        apply_tabbed_geometry(address, monitor)


def handle_close_window(address):
    for path in glob.glob(f"{STATE_DIR}/workspace-*.json"):
        with open(path) as f:
            state = json.load(f)
        if address in state.get("windows", []):
            state["windows"].remove(address)
            with open(path, "w") as f:
                json.dump(state, f)


def handle_move_window(address):
    # Re-check which workspace the window landed on
    clients = hyprctl(["clients"])
    win = None
    for c in clients or []:
        if c.get("address") == address:
            win = c
            break
    if not win:
        return
    ws = win.get("workspace", {}).get("id")
    if ws is None or ws < 0:
        return
    if not is_tabbed(ws):
        return
    if win.get("floating"):
        return

    path = get_state_file(ws)
    with open(path) as f:
        state = json.load(f)
    if address not in state["windows"]:
        state["windows"].append(address)
        with open(path, "w") as f:
            json.dump(state, f)

    monitor = get_monitor_for_workspace(ws)
    if monitor:
        hyprctl_dispatch(["setfloating", f"address:{address}"])
        apply_tabbed_geometry(address, monitor)


def main():
    if len(sys.argv) < 2:
        print("Usage: omarchy-hyprland-tabbed-mode [tabbed|split|toggle|new-window <addr>|close-window <addr>|move-window <addr>]")
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "new-window":
        handle_new_window(sys.argv[2])
        return
    if cmd == "close-window":
        handle_close_window(sys.argv[2])
        return
    if cmd == "move-window":
        handle_move_window(sys.argv[2])
        return
    if cmd == "tabbed-workspace" and len(sys.argv) > 2:
        ws_id = int(sys.argv[2])
        if is_tabbed(ws_id):
            print(f"Workspace {ws_id} already tabbed")
            return
        enable_tabbed(ws_id)
        return

    ws = get_current_workspace()
    if ws is None:
        print("Could not determine current workspace", file=sys.stderr)
        sys.exit(1)

    if cmd == "tabbed":
        if is_tabbed(ws):
            print(f"Workspace {ws} already tabbed")
            return
        enable_tabbed(ws)
    elif cmd == "split":
        if not is_tabbed(ws):
            print(f"Workspace {ws} already split")
            return
        disable_tabbed(ws)
    elif cmd == "toggle":
        if is_tabbed(ws):
            disable_tabbed(ws)
        else:
            enable_tabbed(ws)
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
